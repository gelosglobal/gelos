# Copy to .env locally. On Vercel: Project → Settings → Environment Variables (same names).

# Atlas / local URI (also supported: DATABASE_URL)
MONGODB_URI=
MONGODB_DB_NAME=gelos

# openssl rand -base64 32
BETTER_AUTH_SECRET=

# Required for production: your deployed site URL, no trailing slash
# Example: https://your-project.vercel.app   or   https://your-domain.com
BETTER_AUTH_URL=http://localhost:5173

# Optional: extra origins (comma-separated), only if you need more than BETTER_AUTH_URL
# BETTER_AUTH_TRUSTED_ORIGINS=

# Only if the SPA calls auth on another host (default is same-origin; leave unset on Vercel)
# VITE_AUTH_URL=
