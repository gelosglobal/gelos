# Express (pnpm dev / pnpm start): one process. Vercel: static dist + api/[...path].ts (serverless).

DATABASE_URL=
MONGODB_DB_NAME=gelos
BETTER_AUTH_SECRET=

# Public URL (no trailing slash). Must match the browser URL exactly (including subdomain).
# Local: Express default port
BETTER_AUTH_URL=http://localhost:3005
# Production examples (use YOUR real hostname):
# BETTER_AUTH_URL=https://staff.gelosglobal.com
# BETTER_AUTH_URL=https://staffs.gelosglobal.com

# PORT=3005

# Optional CORS extras (comma-separated)
# BETTER_AUTH_TRUSTED_ORIGINS=

# Only if the SPA is on a different host than the API (usually leave unset)
# VITE_AUTH_URL=
