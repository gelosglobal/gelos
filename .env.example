# gelosglobal.com = Shopify storefront (separate). This app = subdomain only, e.g. staff.gelosglobal.com

# --- Mongo + Better Auth (Vercel serverless + local Express) ---
MONGODB_URI=
# or: DATABASE_URL=
MONGODB_DB_NAME=gelos

# openssl rand -base64 32
BETTER_AUTH_SECRET=

# No trailing slash. Must match the URL users open (same origin as the SPA).
# Local dev (Vite proxies /api/auth → Express :3005):
BETTER_AUTH_URL=http://localhost:5173
# Vercel production (this repo on staff subdomain):
# BETTER_AUTH_URL=https://staff.gelosglobal.com

# Usually leave unset — SPA and /api/auth share the same origin on staff.*.
# VITE_AUTH_URL=
