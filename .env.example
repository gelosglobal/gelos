# --- MongoDB ---
MONGODB_URI=mongodb://127.0.0.1:27017/gelos
# DATABASE_URL=   (alternative)
# DATABASE_URl=   (legacy typo still supported in code)

MONGODB_DB_NAME=gelos

# Replica-set / Atlas: leave unset (default). Standalone local Mongo: false
# MONGODB_TRANSACTIONS=false

# --- Better Auth (required in production) ---
# openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public site URL, no trailing slash. Local dev:
BETTER_AUTH_URL=http://localhost:5173

# On Vercel you can omit this: the app uses https://$VERCEL_URL when unset.
# For a custom domain, set this to https://your-domain.com

# Extra allowed origins (comma-separated), e.g. another frontend or mobile webview:
# BETTER_AUTH_TRUSTED_ORIGINS=https://app.example.com,https://staging.example.com

# --- Standalone Express API only (pnpm dev:auth / start:auth) ---
# AUTH_PORT=3005

# --- Optional: auth API on another host (rare) ---
# VITE_AUTH_URL=https://your-api.example.com
