# One Node process serves the React app (dist/) + /api/auth. Deploy anywhere (Docker, Railway, VPS).

DATABASE_URL=
# or MONGODB_URI=
MONGODB_DB_NAME=gelos
BETTER_AUTH_SECRET=

# Public URL of this app (no trailing slash). Must match the URL in the browser.
# Local with `pnpm dev` (Vite :5173 + API :3005):
BETTER_AUTH_URL=http://localhost:5173
# Production (single server after `pnpm build && pnpm start`):
# BETTER_AUTH_URL=https://staff.gelosglobal.com
# PORT=3000

# Optional extra origins for CORS (comma-separated)
# BETTER_AUTH_TRUSTED_ORIGINS=
