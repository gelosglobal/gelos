{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30,
      "includeFiles": [
        "node_modules/.prisma/**",
        "node_modules/@prisma/**",
        "node_modules/.pnpm/**/.prisma/**",
        "node_modules/.pnpm/**/@prisma/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/auth",
      "destination": "/api/gelos-better-auth"
    },
    {
      "source": "/api/auth/:rest*",
      "destination": "/api/gelos-better-auth"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
